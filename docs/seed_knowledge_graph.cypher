// --- Grammar (215 items) ---
MERGE (g:GrammarPoint {pattern: 'cha ikenai / ja ikenai', level: 'N5'}) SET g.meaning_en = 'must not do (spoken Japanese)', g.meaning_vi = 'không được làm (nói tiếng Nhật)';
MERGE (g:GrammarPoint {pattern: 'da / desu', level: 'N5'}) SET g.meaning_en = 'to be (am, is, are, were, used to)', g.meaning_vi = 'chỉ là (am, is, are, were, used to)';
MERGE (g:GrammarPoint {pattern: 'dake', level: 'N5'}) SET g.meaning_en = 'only; just; as much as ~', g.meaning_vi = 'chỉ một; chỉ; tôi nghĩ là nhiều như ~';
MERGE (g:GrammarPoint {pattern: 'darou', level: 'N5'}) SET g.meaning_en = 'I think; it seems; probably; right?', g.meaning_vi = 'tôi nghĩ; có vẻ như; có lẽ; phải không?';
MERGE (g:GrammarPoint {pattern: 'de', level: 'N5'}) SET g.meaning_en = 'in; at; on; by; with; via ~', g.meaning_vi = 'TRONG; Tại; TRÊN; qua; với; thông qua ~';
MERGE (g:GrammarPoint {pattern: 'demo', level: 'N5'}) SET g.meaning_en = 'but; however; though ~', g.meaning_vi = 'Nhưng; Tuy nhiên; mặc dù ~';
MERGE (g:GrammarPoint {pattern: 'deshou', level: 'N5'}) SET g.meaning_en = 'I think; it seems; probably; right?', g.meaning_vi = 'tôi nghĩ; có vẻ như; có lẽ; phải không?';
MERGE (g:GrammarPoint {pattern: 'donna', level: 'N5'}) SET g.meaning_en = 'what kind of; what sort of', g.meaning_vi = 'loại gì; tại sao lại là loại';
MERGE (g:GrammarPoint {pattern: 'doushite', level: 'N5'}) SET g.meaning_en = 'why; for what reason; how', g.meaning_vi = 'Tại sao; vì lý do gì; thế nào';
