{
  "name": "JPLearning Assistant",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.dev.yml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": "true",
      "installGradle": "false"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "customizations": {
    "vscode": {
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic",
        "java.server.launchMode": "Standard",
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "[java]": {
          "editor.defaultFormatter": "redhat.java"
        },
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      },
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "humao.rest-client",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker",
        "eamodio.gitlens"
      ]
    }
  },

  "forwardPorts": [
    8080,
    8000,
    5432,
    7474,
    7687,
    6333,
    8501
  ],

  "portsAttributes": {
    "8080": { "label": "Spring Boot API",   "onAutoForward": "notify" },
    "8000": { "label": "Python AI Service", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL",        "onAutoForward": "silent" },
    "7474": { "label": "Neo4j Browser",     "onAutoForward": "notify" },
    "7687": { "label": "Neo4j Bolt",        "onAutoForward": "silent" },
    "6333": { "label": "Qdrant REST",       "onAutoForward": "silent" },
    "8501": { "label": "Frontend",          "onAutoForward": "notify" }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "remoteEnv": {
    "POSTGRES_HOST": "postgres",
    "POSTGRES_PORT": "5432",
    "POSTGRES_USER": "${localEnv:POSTGRES_USER:jpassistant}",
    "POSTGRES_PASSWORD": "${localEnv:POSTGRES_PASSWORD:jpassistant123}",
    "POSTGRES_DB": "${localEnv:POSTGRES_DB:jpassistant}",
    "NEO4J_URI": "bolt://neo4j:7687",
    "NEO4J_USER": "${localEnv:NEO4J_USER:neo4j}",
    "NEO4J_PASSWORD": "${localEnv:NEO4J_PASSWORD:neo4jpassword}",
    "QDRANT_HOST": "qdrant",
    "QDRANT_PORT": "6333",
    "AI_SERVICE_URL": "http://devcontainer:8000"
  }
}
