# PostgreSQL credentials
POSTGRES_USER=jpassistant
POSTGRES_PASSWORD=jpassistant123
POSTGRES_DB=jpassistant

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_URI=bolt://localhost:7687

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=mock

# Services Configuration
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/jpassistant
SPRING_NEO4J_URI=bolt://localhost:7687
AI_SERVICE_URL=http://localhost:8000
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=jp_learning_knowledge
EMBEDDING_PROVIDER=ollama
EMBEDDING_VECTOR_SIZE=1024
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_TIMEOUT_SECONDS=120
AI_SERVICE_TIMEOUT=12s
